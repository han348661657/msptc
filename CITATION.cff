    given-names: Zhaohui
    email: hzh1211@gmail.com
license: MIT
repository-code: "https://github.com/han348661657/msptc"
version: "1.0.0"
date-released: "2026-06-26"
keywords:
  - concentrating solar power
  - parabolic trough collector
  - molten salt
  - high-altitude
  - intercept factor
